# Google Calendar embed URL only (paste the calendar embed URL, not the full <iframe> tag)
# Example: https://calendar.google.com/calendar/embed?src=...&ctz=Europe%2FIstanbul
VITE_GOOGLE_CALENDAR_EMBED_URL=

# SheetDB API URL from https://sheetdb.io (sheet → API URL)
# Example: https://sheetdb.io/api/v1/xxxx
# POST body keys must match sheet row 1 exactly (see src/lib/submitDemo.ts).
VITE_SHEETDB_API_URL=

# SheetDB bearer token (if you enabled API protection). Paste token only, or full "Bearer xxx".
# Warning: VITE_* vars ship to the browser — anyone can see them. For high-sensitivity data use a server proxy.
VITE_SHEETDB_BEARER_TOKEN=
